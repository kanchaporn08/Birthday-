<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Birthday Surprise</title>
<style>
body{
margin:0;
font-family:Arial;
background:linear-gradient(135deg,#ff9a9e,#fad0c4);
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}
.card{
background:white;
padding:20px;
border-radius:20px;
width:90%;
max-width:400px;
text-align:center;
}
.slider img{width:100%;border-radius:15px;display:none;}
.slider img.active{display:block;}
button{
margin-top:15px;
padding:10px;
border:none;
border-radius:10px;
background:#ff4d6d;
color:white;
}
</style>
</head>
<body>

<div class="card">
<h1>Happy Birthday My Love ❤️</h1>
<p>Every picture is of the person I love. ❤️</p>

<div class="slider">
<img src="photo1.jpg" class="active">
<img src="photo2.jpg">
<img src="photo3.jpg">
</div>

<button onclick="document.getElementById('music').play()">Open My Gift 🎁</button>

<audio id="music" src="hbd(1).mp3"></audio>
</div>

<script>
let i=0;
const imgs=document.querySelectorAll(".slider img");
setInterval(()=>{
imgs[i].classList.remove("active");
i=(i+1)%imgs.length;
imgs[i].classList.add("active");
},2500);
</script>

</body>
</html>
